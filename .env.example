# Capital Sense environment variables
#
# Backend reads DATABASE_URL from the project root .env or backend/.env.
# Frontend variables are read by Next.js when set in frontend/.env.local or in the deployment provider.

# Backend - Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-host.region.aws.neon.tech/dbname?sslmode=require

# Backend - server port
# Railway injects PORT automatically. For local uvicorn, you usually do not need this.
PORT=8000

# Frontend - public API base URL used by axios calls
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend/Next server - private beta login access code
ACCESS_CODE=change-this-access-code

# Frontend/Next server - admin login access code
ADMIN_ACCESS_CODE=change-this-admin-code

# Backend + Next admin proxy - token required for admin review reads
ADMIN_API_TOKEN=change-this-admin-api-token

# Backend - comma-separated frontend origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:3000

# Backend - per-IP request limit per minute
RATE_LIMIT_PER_MINUTE=60
